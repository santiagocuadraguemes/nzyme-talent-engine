# Notion API
NOTION_KEY=secret_xxx
NOTION_MAIN_DB_ID=xxx
NOTION_PROCESS_DASHBOARD_DB_ID=xxx
NOTION_PROCESS_LAUNCHER_DB_ID=xxx
NOTION_GUIDELINES_DB_ID=xxx
NOTION_REFERENCES_DB_ID=xxx

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=xxx

# OpenAI
OPENAI_API_KEY=sk-xxx

# Exa.ai (Optional: enables LinkedIn enrichment)
EXA_API_KEY=xxx

# Logfire (Optional: enables OpenAI tracing)
LOGFIRE_TOKEN=xxx

# Logging
# Set to DEBUG for full traceability (webhook routing, handler dispatch, registry lookups)
LOG_LEVEL=INFO

# Webhook Feature Flags (set to "true" to enable, default: disabled)
WEBHOOK_PROCESS_DASHBOARD_ENABLED=false
WEBHOOK_MAIN_CANDIDATE_ENABLED=false
WEBHOOK_CENTRAL_REFERENCE_ENABLED=false
WEBHOOK_WORKFLOW_ENABLED=false
WEBHOOK_FEEDBACK_ENABLED=false
WEBHOOK_FORM_SUBMISSION_ENABLED=false
WEBHOOK_BULK_SUBMISSION_ENABLED=false
WEBHOOK_OUTCOME_ENABLED=false
